{
  "name": "edgin-personal-assigning-app",
  "version": "1.0.0",
  "description": "Desktop wrapper for the Edgin Personal Assigning App",
  "main": "main.js",
  "author": "Kuya Medward",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.kuya-medward.edgin-personal-assigning-app",
    "productName": "Edgin Personal Assigning App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "Sidepic.png",
      "main.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Edgin Personal Assigning App"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
